                    point3f physics:localPos1 = (0, 0, 0)
                    quatf physics:localRot0 = (0.70710546, 0.7071081, 0, 0)
                    quatf physics:localRot1 = (1, 0, 0, 0)
                }
            }

            def PhysicsFixedJoint "PhysicsFixedJoint"
            {
                custom rel physics:body0
                prepend rel physics:body0 = </openarm>
                custom rel physics:body1
                prepend rel physics:body1 = </openarm/Geometry/openarm_body_link0>
                point3f physics:localPos0 = (0.185, 0, 0.34)
                point3f physics:localPos1 = (0, 0, 0)
                quatf physics:localRot0 = (1, 0, 0, 0)
                quatf physics:localRot1 = (1, 0, 0, 0)
            }
        }
    }

    over "Physics"
    {
        over "PhysicsMaterial" (
            prepend apiSchemas = ["PhysicsMaterialAPI", "NewtonMaterialAPI"]
        )
        {
            float newton:rollingFriction = 0.01
            float newton:torsionalFriction = 0.01
            float physics:dynamicFriction = 1
        }

        over "PhysicsMaterial_1" (
            prepend apiSchemas = ["PhysicsMaterialAPI", "NewtonMaterialAPI"]
        )
        {
            float newton:rollingFriction = 0.0001
            float newton:torsionalFriction = 0.005
            float physics:dynamicFriction = 1
        }
    }
}

def PhysicsScene "PhysicsScene" (
    prepend apiSchemas = ["NewtonSceneAPI"]
)
{
    uniform int newton:maxSolverIterations = 100
    uniform int newton:timeStepsPerSecond = 500
    vector3f physics:gravityDirection = (0, 0, -1)
    float physics:gravityMagnitude = 9.81
}

